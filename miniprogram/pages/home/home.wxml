<view class="form-container">
  <form bindsubmit="formSubmit" bindreset="formReset">
    <!-- 姓名 -->
    <view class="form-item">
      <label class="form-label">姓名</label>
      <input class="form-input" name="name" placeholder="请输入姓名" value="{{formData.name}}" bindinput="handleInput" data-key="name" />
    </view>

    <!-- 科室 -->
    <view class="form-item">
      <label class="form-label">科室</label>
      <input class="form-input" name="department" placeholder="请输入科室" value="{{formData.department}}" bindinput="handleInput" data-key="department" />
    </view>

    <!-- 项目 -->
    <view class="form-item">
      <label class="form-label">项目</label>
      <picker mode="selector" range="{{projectOptions}}" value="{{projectIndex}}" bindchange="handleProjectChange">
        <view class="form-input placeholder">
          {{formData.project || '请选择项目类型'}}
        </view>
      </picker>
    </view>

    <!-- 方向 -->
    <view class="form-item">
      <label class="form-label">方向</label>
      <input class="form-input" name="direction" placeholder="请输入项目方向" value="{{formData.direction}}" bindinput="handleInput" data-key="direction" />
    </view>

    <!-- 交付时间 -->
    <view class="form-item">
      <label class="form-label">交付时间</label>
      <picker mode="date" value="{{formData.deliveryTime}}" bindchange="handleDateChange" start="{{today}}">
        <view class="form-input placeholder">
          {{formData.deliveryTime || '请选择交付日期'}}
        </view>
      </picker>
    </view>

    <!-- 费用 -->
    <view class="form-item">
      <label class="form-label">费用</label>
      <input class="form-input" name="fee" type="digit" placeholder="请输入费用金额" value="{{formData.fee}}" bindinput="handleInput" data-key="fee" />
    </view>

    <!-- 已付 -->
    <view class="form-item form-item-switch">
      <label class="form-label">已付</label>
      <view class="switch-wrapper">
        <switch checked="{{formData.paid}}" bindchange="handleSwitchChange" data-key="paid" />
        <text class="switch-text">{{formData.paid ? '是' : '否'}}</text>
      </view>
    </view>

    <!-- 备注 -->
    <view class="form-item">
      <label class="form-label">备注</label>
      <textarea class="form-textarea" name="remark" placeholder="请输入备注信息（选填）" value="{{formData.remark}}" bindinput="handleInput" data-key="remark" maxlength="200" />
    </view>

    <!-- 文件上传 -->
    <view class="form-item">
      <label class="form-label">相关文件</label>
      <view class="file-upload">
        <button class="upload-btn" bindtap="chooseFile" disabled="{{uploading}}">
          <text>{{uploading ? '上传中...' : '选择文件'}}</text>
        </button>
        <view class="file-list">
          <view class="file-item" wx:for="{{formData.files}}" wx:key="url">
            <view class="file-info">
              <text class="file-name">{{item.name}}</text>
              <text class="file-size">{{item.displaySize}}</text>
            </view>
            <view class="file-actions">
              <button class="file-action-btn" bindtap="removeFile" data-index="{{index}}">删除</button>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 提交人 -->
    <view class="form-item">
      <label class="form-label">提交人</label>
      <input class="form-input" name="submitUserName" placeholder="请输入提交人" value="{{formData.submitUserName}}" bindinput="handleInput" data-key="submitUserName" />
    </view>

    <!-- 提交按钮组 -->
    <view class="form-btn-group">
      <button form-type="reset" class="reset-btn">重置</button>
      <button form-type="submit" class="submit-btn" loading="{{loading}}">提交</button>
    </view>
  </form>
</view>