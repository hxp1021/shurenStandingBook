<view class="list-container">
  <!-- 筛选栏 -->
  <view class="filter-bar">
    <picker 
      mode="selector" 
      range="{{deliveryFilterOptions}}" 
      value="{{currentFilter}}" 
      bindchange="handleFilterChange"
    >
      <view class="filter-btn">
        {{deliveryFilterOptions[currentFilter]}}
        <icon type="down" size="14"></icon>
      </view>
    </picker>
    <input 
      class="search-input" 
      placeholder="搜索姓名/项目" 
      value="{{searchKeyword}}"
      bindinput="handleSearchInput"
      confirm-type="search"
      bindconfirm="handleSearch"
    />
  </view>

  <!-- 数据列表 -->
  <scroll-view 
    class="list-scroll"
    scroll-y
    refresher-enabled="true"
    bindrefresherrefresh="onPullDownRefresh"
    bindscrolltolower="onReachBottom"
    refresher-triggered="{{refreshing}}"
  >
    <!-- 空数据提示 -->
    <view class="empty-tip" wx:if="{{listData.length === 0 && !loading}}">
      <text>暂无数据</text>
    </view>

    <!-- 列表项 -->
    <view class="list-item" wx:for="{{listData}}" wx:key="_id">
      <view class="item-row">
        <text class="label">姓名：</text>
        <text class="value">{{item.name}}</text>
      </view>
      <view class="item-row">
        <text class="label">科室：</text>
        <text class="value">{{item.department}}</text>
      </view>
      <view class="item-row">
        <text class="label">项目：</text>
        <text class="value">{{item.project}}</text>
      </view>
      <view class="item-row">
        <text class="label">方向：</text>
        <text class="value">{{item.direction}}</text>
      </view>
      <view class="item-row">
        <text class="label">交付时间：</text>
        <text class="value">{{item.deliveryTime}}</text>
      </view>
      <view class="item-row">
        <text class="label">费用：</text>
        <text class="value">¥{{item.fee}}</text>
      </view>
      <view class="item-row">
        <text class="label">已付：</text>
        <text class="value {{item.paid ? 'paid' : 'unpaid'}}">{{item.paid ? '是' : '否'}}</text>
      </view>
      <view class="item-row">
        <text class="label">交付状态：</text>
        <text class="value status-{{item.deliveryStatus === '已交付' ? 'done' : (item.deliveryStatus === '部分交付' ? 'partial' : 'undone')}}">
          {{item.deliveryStatus}}
        </text>
      </view>
      <view class="item-row" wx:if="{{item.remark}}">
        <text class="label">备注：</text>
        <text class="value">{{item.remark}}</text>
      </view>
    </view>

    <!-- 加载中提示 -->
    <view class="loading-tip" wx:if="{{loading}}">
      <loading size="20">加载中...</loading>
    </view>

    <!-- 没有更多数据 -->
    <view class="no-more-tip" wx:if="{{!loading && !hasMore}}">
      <text>没有更多数据了</text>
    </view>
  </scroll-view>
</view>